{
  "id": "discord",
  "name": "Discord",
  "version": "1.1.0",
  "minAgent": "1.3.0",
  "sdk": 3,
  "entry": "plugin.js",
  "permissions": {
    "pipe": ["discord-ipc-*"],
    "net": ["discord.com", "cdn.discordapp.com"]
  },
  "settings": [
    { "key": "showChannelName", "type": "bool", "label": "Показывать название канала", "default": true }
  ]
}
