{
  "id": "discord",
  "name": "Discord",
  "version": "1.2.0",
  "minAgent": "1.3.0",
  "sdk": 3,
  "entry": "plugin.js",
  "permissions": {
    "pipe": ["discord-ipc-*"],
    "net": ["discord.com", "cdn.discordapp.com"],
    "notifications": true
  },
  "settings": [
    { "key": "notifyJoin", "type": "bool", "label": "Уведомлять о входе в созвон", "default": true }
  ]
}
